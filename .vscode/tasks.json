{
  "version": "2.0.0",
  "tasks": [
    // VIBESTUDIO APP TASKS
    {
      "label": "📱 VibeStudio App: Watch",
      "type": "shell",
      "command": "cd ${workspaceFolder}/vibestudio-app && yarn watch",
      "problemMatcher": ["$tsc-watch"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "dev"
      },
      "detail": "Run VibeStudio App in watch mode"
    },
    {
      "label": "📱 VibeStudio App: Install Dependencies",
      "type": "shell",
      "command": "cd ${workspaceFolder}/vibestudio-app && ./scripts/pearai/install-dependencies.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "setup"
      },
      "detail": "Install dependencies for VibeStudio App"
    },

    // VIBESTUDIO SUBMODULE TASKS
    {
      "label": "🧩 Submodule: Install and Build",
      "type": "shell",
      "command": "cd ${workspaceFolder}/vibestudio-submodule && ./scripts/install-and-build.sh",
      "problemMatcher": ["$tsc"],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "setup"
      },
      "detail": "Install and build VibeStudio Submodule"
    },
    {
      "label": "🧩 Submodule: ESBuild Watch",
      "type": "shell",
      "command": "cd ${workspaceFolder}/vibestudio-submodule/extensions/vscode && npm run esbuild-watch",
      "problemMatcher": ["$tsc-watch"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "dev"
      },
      "detail": "Run ESBuild in watch mode for VSCode extension"
    },
    {
      "label": "🧩 Submodule: TSC Watch",
      "type": "shell",
      "command": "cd ${workspaceFolder}/vibestudio-submodule/extensions/vscode && npm run tsc-watch",
      "problemMatcher": ["$tsc-watch"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "dev"
      },
      "detail": "Run TypeScript compiler in watch mode for VSCode extension"
    },
    {
      "label": "🧩 Submodule: GUI Dev",
      "type": "shell",
      "command": "cd ${workspaceFolder}/vibestudio-submodule/gui && npm run dev",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "dev"
      },
      "detail": "Run Vite dev server for GUI component"
    },

    // VIBESTUDIO ROO CODE TASKS
    {
      "label": "🚀 Roo Code: Watch",
      "type": "shell",
      "command": "cd ${workspaceFolder}/VibeStudio-Roo-Code && npm run watch",
      "problemMatcher": ["$tsc-watch"],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "dev"
      },
      "detail": "Run VibeStudio Roo Code in watch mode"
    },
    {
      "label": "🚀 Roo Code: Dev",
      "type": "shell",
      "command": "cd ${workspaceFolder}/VibeStudio-Roo-Code && npm run dev",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "dev"
      },
      "detail": "Run VibeStudio Roo Code dev server"
    },
    {
      "label": "🚀 Roo Code: Install All",
      "type": "shell",
      "command": "cd ${workspaceFolder}/VibeStudio-Roo-Code && npm run install:all",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "setup"
      },
      "detail": "Install all dependencies for VibeStudio Roo Code"
    },

    // UTILITY TASKS
    {
      "label": "🔄 Setup All Dev",
      "type": "shell",
      "command": "${workspaceFolder}/setup-app-dev.sh",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "setup"
      },
      "detail": "Run setup script for all components"
    },

    // COMPOUND TASKS
    {
      "label": "🚀 Start All Dev Servers",
      "dependsOn": [
        "📱 VibeStudio App: Watch",
        "🧩 Submodule: ESBuild Watch",
        "🧩 Submodule: TSC Watch",
        "🧩 Submodule: GUI Dev",
        "🚀 Roo Code: Watch",
        "🚀 Roo Code: Dev"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}